","        // Send a message to notify the kernel that we're ready.\n","        channel.send({})\n","        if (message.buffers) {\n","          for (const buffer of message.buffers) {\n","            buffers.push(buffer);\n","            downloaded += buffer.byteLength;\n","            progress.value = downloaded;\n","          }\n","        }\n","      }\n","      const blob = new Blob(buffers, {type: 'application/binary'});\n","      const a = document.createElement('a');\n","      a.href = window.URL.createObjectURL(blob);\n","      a.download = filename;\n","      div.appendChild(a);\n","      a.click();\n","      div.remove();\n","    }\n","  "]},"metadata":{}},{"output_type":"display_data","data":{"text/plain":["<IPython.core.display.Javascript object>"],"application/javascript":["download(\"download_053a0323-be32-40d7-b656-db026c8719d4\", \"report.html\", 12994423)"]},"metadata":{}}],"source":["df = pd.read_csv(\n","    \"https://raw.githubusercontent.com/sonofastronaut/test_mts/main/telco-customer-churn.csv\"\n",")\n","\n","profile = ProfileReport(df)\n","profile.to_file(\"report.html\")\n","files.download(\"report.html\")\n"]},{"cell_type":"code","execution_count":4,"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"executionInfo":{"elapsed":24,"status":"ok","timestamp":1769953489431,"user":{"displayName":"Егор Ковалёв","userId":"01841628920051786186"},"user_tz":-300},"id":"l4YOGIjAGqwt","outputId":"2429bbe1-cece-4936-bb7d-47de11399de0"},"outputs":[{"output_type":"stream","name":"stdout","text":["\n","Доля пропусков по колонкам:\n"," age                                     0.0\n","annualincome                            0.0\n","calldroprate                            0.0\n","callfailurerate                         0.0\n","callingnum                              0.0\n","customerid                              0.0\n","customersuspended                       0.0\n","education                               0.0\n","gender                                  0.0\n","homeowner                               0.0\n","maritalstatus                           0.0\n","monthlybilledamount                     0.0\n","noadditionallines                       0.0\n","numberofcomplaints                      0.0\n","numberofmonthunpaid                     0.0\n","numdayscontractequipmentplanexpiring    0.0\n","occupation                              0.0\n","penaltytoswitch                         0.0\n","state                                   0.0\n","totalminsusedinlastmonth                0.0\n","unpaidbalance                           0.0\n","usesinternetservice                     0.0\n","usesvoiceservice                        0.0\n","percentagecalloutsidenetwork            0.0\n","totalcallduration                       0.0\n","avgcallduration                         0.0\n","churn                                   0.0\n","year                                    0.0\n","month                                   0.0\n","dtype: float64\n","\n","Количество дубликатов: 0\n"]}],"source":["# пропуски\n","missing = df.isna().mean().sort_values(ascending=False)\n","print(\"\\nДоля пропусков по колонкам:\\n\", missing)\n","\n","# дубликаты\n","duplicates_count = df.duplicated().sum()\n","print(\"\\nКоличество дубликатов:\", duplicates_count)\n"]},{"cell_type":"markdown","metadata":{"id":"-4qWxtXs-nQ4"},"source":["Откроем и проанализируем датасет. Размер сета 20468 строк на 29 столбцов, среди столбцов есть категориальные значения, которые необходимо предобработать. Так же отдельно отмечу, что в датасете полностью отсутствуют пропуски, дубликаты или ячейки со значением NULL, что исключает необходимость в обработке числовых значений. Однако, при рассмотрении датасета видно, что в нем есть столбец noadditionallines, в котором все значения равны \\N, что говорит о неинформативности данного столбца, покажу ниже"]},{"cell_type":"code","execution_count":5,"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"executionInfo":{"elapsed":38,"status":"ok","timestamp":1769953489479,"user":{"displayName":"Егор Ковалёв","userId":"01841628920051786186"},"user_tz":-300},"id":"Ct4PaRt28loG","outputId":"28daa8fc-e829-4c25-fa3c-cc217af5c4c7"},"outputs":[{"output_type":"stream","name":"stdout","text":["Всего столбцов: 29\n","Столбцов с значением '\\N': 1\n","\n","Распределение значений '\\N' по столбцам:\n","  noadditionallines: 20468 строк (100.00%)\n"]}],"source":["# \\N-значения\n","null_counts = {}\n","for column in df.columns:\n","    # Считаем точные совпадения с '\\N'\n","    count = (df[column] == '\\\\N').sum()\n","    if count > 0:\n","        null_counts[column] = count\n","\n","# Вывод результатов\n","print(f\"Всего столбцов: {len(df.columns)}\")\n","print(f\"Столбцов с значением '\\\\N': {len(null_counts)}\")\n","print(\"\\nРаспределение значений '\\\\N' по столбцам:\")\n","if null_counts:\n","    for col, count in null_counts.items():\n","        percentage = (count / len(df)) * 100\n","        print(f\"  {col}: {count} строк ({percentage:.2f}%)\")\n","else:\n","    print(\"  Значения '\\\\N' не найдены\")"]},{"cell_type":"markdown","metadata":{"id":"uJNo4v0QvOBY"},"source":["Учитывая отсутствие хоть какой-то информативности в этом столбце, считаю, что его стоит исключить из датасета"]},{"cell_type":"markdown","metadata":{"id":"KDhr8e3wJMMs"},"source":["Так же перед кодированием категориальных столбцов, я рассмотрю количество уникальных значений в каждой колонке"]},{"cell_type":"code","execution_count":6,"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"executionInfo":{"elapsed":41,"status":"ok","timestamp":1769953489527,"user":{"displayName":"Егор Ковалёв","userId":"01841628920051786186"},"user_tz":-300},"id":"a2pGKGDqI4lx","outputId":"488003b0-9665-4e4b-f915-03e1b67828b1"},"outputs":[{"output_type":"stream","name":"stdout","text":["Уникальные значения в категориальных столбцах:\n","==================================================\n","\n","customersuspended:\n","  Уникальных значений: 2\n","\n","education:\n","  Уникальных значений: 4\n","\n","gender:\n","  Уникальных значений: 2\n","\n","homeowner:\n","  Уникальных значений: 2\n","\n","maritalstatus:\n","  Уникальных значений: 2\n","\n","noadditionallines:\n","  Уникальных значений: 1\n","\n","occupation:\n","  Уникальных значений: 3\n","\n","state:\n","  Уникальных значений: 50\n","\n","usesinternetservice:\n","  Уникальных значений: 2\n","\n","usesvoiceservice:\n","  Уникальных значений: 2\n"]}],"source":["# Вывод количества уникальных значений в каждой колонке\n","cat_cols = df.select_dtypes(include=['object']).columns\n","\n","print(\"Уникальные значения в категориальных столбцах:\")\n","print(\"=\" * 50)\n","\n","for col in cat_cols:\n","    unique_count = df[col].nunique()\n","    print(f\"\\n{col}:\")\n","    print(f\"  Уникальных значений: {unique_count}\")"]},{"cell_type":"markdown","metadata":{"id":"SIPx8_wsJdJd"},"source":["Внимание стоит обратить на столбец state, в котором есть 50 уникальных значений, что при OHE даст нам 50 новых столбцов, тогда как в самом датасете их 29. Решение об удалении этого столбца я приму после построения матрицы корреляций"]},{"cell_type":"markdown","metadata":{"id":"kyO1imuu1B02"},"source":["Далее рассмотрим, как распределена целевая переменная"]},{"cell_type":"code","execution_count":7,"metadata":{"colab":{"base_uri":"https://localhost:8080/","height":514},"executionInfo":{"elapsed":202,"status":"ok","timestamp":1769953489727,"user":{"displayName":"Егор Ковалёв","userId":"01841628920051786186"},"user_tz":-300},"id":"fZRu6y9Uv7iV","outputId":"c6d2f042-65d2-4670-c71e-db0c805b1174"},"outputs":[{"output_type":"display_data","data":{"text/plain":["<Figure size 600x400 with 1 Axes>"],"image/png":"\n"},"metadata":{}},{"output_type":"stream","name":"stdout","text":["\n","Доли классов:\n","churn\n","0    0.90898\n","1    0.09102\n","Name: proportion, dtype: float64\n"]}],"source":["# распределение целевой переменной\n","\n","plt.figure(figsize=(6, 4))\n","sns.countplot(x=\"churn\", data=df)\n","plt.title(\"Распределение целевой переменной churn\")\n","plt.xlabel(\"Churn\")\n","plt.ylabel(\"Количество\")\n","plt.show()\n","\n","print(\"\\nДоли классов:\")\n","print(df[\"churn\"].value_counts(normalize=True))"]},{"cell_type":"markdown","metadata":{"id":"6jXrZEeaBwRX"},"source":["В распределении целевой переменной виден явный дисбаланс, но стоит отметить, что в телекоме такое распределение можно назвать ожидаемым, потому что люди довольно редко меняют оператора связи. При дальнейшей обработке данного датасета я должен учесть этот дисбаланс"]},{"cell_type":"code","execution_count":8,"metadata":{"colab":{"base_uri":"https://localhost:8080/","height":814},"executionInfo":{"elapsed":472,"status":"ok","timestamp":1769953490200,"user":{"displayName":"Егор Ковалёв","userId":"01841628920051786186"},"user_tz":-300},"id":"S8lod_3XwBeU","outputId":"cc18a346-dfaf-496f-b977-d200166308f3"},"outputs":[{"output_type":"display_data","data":{"text/plain":["<Figure size 1000x600 with 2 Axes>"],"image/png":"\n"},"metadata":{}}],"source":["# Корреляции числовых признаков\n","\n","df_corr = df.copy()\n","df_corr[\"churn\"] = df_corr[\"churn\"].astype(int)\n","\n","num_cols_corr = df_corr.select_dtypes(include=[np.number])\n","\n","plt.figure(figsize=(10, 6))\n","sns.heatmap(\n","    num_cols_corr.corr(),\n","    cmap=\"Reds\",\n","    center=0,\n","    linewidths=0.5\n",")\n","plt.title(\"Матрица корреляций числовых признаков\")\n","\n","plt.show()\n"]},{"cell_type":"code","source":["target_corr = (\n","    num_cols_corr\n","        .corr()[\"churn\"]\n","        .drop(\"churn\")\n","        .abs()\n","        .sort_values(ascending=False)\n",")\n","\n","target_corr"],"metadata":{"colab":{"base_uri":"https://localhost:8080/","height":648},"id":"6GA2vmA9G_Dv","executionInfo":{"status":"ok","timestamp":1769953490203,"user_tz":-300,"elapsed":2,"user":{"displayName":"Егор Ковалёв","userId":"01841628920051786186"}},"outputId":"17ef7f07-0da5-4a4d-bd17-288e6f8f6aea"},"execution_count":9,"outputs":[{"output_type":"execute_result","data":{"text/plain":["age                                     0.137655\n","numberofcomplaints                      0.054646\n","unpaidbalance                           0.047482\n","numdayscontractequipmentplanexpiring    0.017892\n","percentagecalloutsidenetwork            0.012896\n","totalcallduration                       0.010087\n","monthlybilledamount                     0.009842\n","callingnum                              0.009410\n","calldroprate                            0.006906\n","numberofmonthunpaid                     0.005232\n","month                                   0.004760\n","totalminsusedinlastmonth                0.003791\n","callfailurerate                         0.003483\n","customerid                              0.002439\n","penaltytoswitch                         0.002050\n","avgcallduration                         0.001881\n","annualincome                            0.001800\n","year                                         NaN\n","Name: churn, dtype: float64"],"text/html":["<div>\n","<style scoped>\n","    .dataframe tbody tr th:only-of-type {\n","        vertical-align: middle;\n","    }\n","\n","    .dataframe tbody tr th {\n","        vertical-align: top;\n","    }\n","\n","    .dataframe thead th {\n","        text-align: right;\n","    }\n","</style>\n","<table border=\"1\" class=\"dataframe\">\n","  <thead>\n","    <tr style=\"text-align: right;\">\n","      <th></th>\n","      <th>churn</th>\n","    </tr>\n","  </thead>\n","  <tbody>\n","    <tr>\n","      <th>age</th>\n","      <td>0.137655</td>\n","    </tr>\n","    <tr>\n","      <th>numberofcomplaints</th>\n","      <td>0.054646</td>\n","    </tr>\n","    <tr>\n","      <th>unpaidbalance</th>\n","      <td>0.047482</td>\n","    </tr>\n","    <tr>\n","      <th>numdayscontractequipmentplanexpiring</th>\n","      <td>0.017892</td>\n","    </tr>\n","    <tr>\n","      <th>percentagecalloutsidenetwork</th>\n","      <td>0.012896</td>\n","    </tr>\n","    <tr>\n","      <th>totalcallduration</th>\n","      <td>0.010087</td>\n","    </tr>\n","    <tr>\n","      <th>monthlybilledamount</th>\n","      <td>0.009842</td>\n","    </tr>\n","    <tr>\n","      <th>callingnum</th>\n","      <td>0.009410</td>\n","    </tr>\n","    <tr>\n","      <th>calldroprate</th>\n","      <td>0.006906</td>\n","    </tr>\n","    <tr>\n","      <th>numberofmonthunpaid</th>\n","      <td>0.005232</td>\n","    </tr>\n","    <tr>\n","      <th>month</th>\n","      <td>0.004760</td>\n","    </tr>\n","    <tr>\n","      <th>totalminsusedinlastmonth</th>\n","      <td>0.003791</td>\n","    </tr>\n","    <tr>\n","      <th>callfailurerate</th>\n","      <td>0.003483</td>\n","    </tr>\n","    <tr>\n","      <th>customerid</th>\n","      <td>0.002439</td>\n","    </tr>\n","    <tr>\n","      <th>penaltytoswitch</th>\n","      <td>0.002050</td>\n","    </tr>\n","    <tr>\n","      <th>avgcallduration</th>\n","      <td>0.001881</td>\n","    </tr>\n","    <tr>\n","      <th>annualincome</th>\n","      <td>0.001800</td>\n","    </tr>\n","    <tr>\n","      <th>year</th>\n","      <td>NaN</td>\n","    </tr>\n","  </tbody>\n","</table>\n","</div><br><label><b>dtype:</b> float64</label>"]},"metadata":{},"execution_count":9}]},{"cell_type":"markdown","source":["Судя по полученному хитмапу, фича year не имеет корреляции как таковой, посмотрим количество уникальных значений"],"metadata":{"id":"HTn0K2HXFV7q"}},{"cell_type":"code","source":["print(f\"year: \\nУникальных значений: {df['year'].nunique()}\")\n"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"sebcJKKQFfeK","executionInfo":{"status":"ok","timestamp":1769953490222,"user_tz":-300,"elapsed":13,"user":{"displayName":"Егор Ковалёв","userId":"01841628920051786186"}},"outputId":"433ca9da-2d00-443c-fc5d-c04863bfbfeb"},"execution_count":10,"outputs":[{"output_type":"stream","name":"stdout","text":["year: \n","Уникальных значений: 1\n"]}]},{"cell_type":"markdown","source":["В колонке year всего лишь одно уникальное значение 2015, неинформативно, предсказательной нагрузки не несет, можем удалять"],"metadata":{"id":"qdVYp-IrGfk3"}},{"cell_type":"markdown","metadata":{"id":"kTK6woyyvrhb"},"source":["Далее рассмотрим корреляцию категориальных признаков с целевой переменной. Предварительно удалим столбец noadditionallines, т.к. его нецелесообразно обрабатывать"]},{"cell_type":"code","source":["df.drop(columns=[\"noadditionallines\"], inplace=True)"],"metadata":{"id":"JiiO2PL4RSvd","executionInfo":{"status":"ok","timestamp":1769953490230,"user_tz":-300,"elapsed":8,"user":{"displayName":"Егор Ковалёв","userId":"01841628920051786186"}}},"execution_count":11,"outputs":[]},{"cell_type":"code","execution_count":12,"metadata":{"executionInfo":{"elapsed":10,"status":"ok","timestamp":1769953490246,"user":{"displayName":"Егор Ковалёв","userId":"01841628920051786186"},"user_tz":-300},"id":"pzjsACYytzFu"},"outputs":[],"source":["import scipy.stats as ss\n","\n","def cramers_v(x, y):\n","    confusion_matrix = pd.crosstab(x, y)\n","    chi2 = ss.chi2_contingency(confusion_matrix)[0]\n","    n = confusion_matrix.sum().sum()\n","    r, k = confusion_matrix.shape\n","    return np.sqrt(chi2 / (n * (min(r, k) - 1)))"]},{"cell_type":"code","execution_count":13,"metadata":{"colab":{"base_uri":"https://localhost:8080/","height":979},"executionInfo":{"elapsed":1495,"status":"ok","timestamp":1769953491750,"user":{"displayName":"Егор Ковалёв","userId":"01841628920051786186"},"user_tz":-300},"id":"x0GjzkhKudR2","outputId":"9da308e4-eec1-4353-d38a-0df5394d66d4"},"outputs":[{"output_type":"display_data","data":{"text/plain":["<Figure size 1200x1000 with 2 Axes>"],"image/png":"\n"},"metadata":{}}],"source":["cat_cols = df.select_dtypes(include='object').columns\n","\n","cramers_matrix = pd.DataFrame(\n","    np.zeros((len(cat_cols), len(cat_cols))),\n","    index=cat_cols,\n","    columns=cat_cols\n",")\n","\n","for col1 in cat_cols:\n","    for col2 in cat_cols:\n","        cramers_matrix.loc[col1, col2] = cramers_v(df[col1], df[col2])\n","\n","plt.figure(figsize=(12, 10))\n","sns.heatmap(\n","    cramers_matrix,\n","    cmap=\"Reds\",\n","    linewidths=0.5\n",")\n","plt.title(\"Корреляция категориальных признаков\")\n","plt.show()\n","\n"]},{"cell_type":"code","execution_count":14,"metadata":{"colab":{"base_uri":"https://localhost:8080/","height":366},"executionInfo":{"elapsed":133,"status":"ok","timestamp":1769953491883,"user":{"displayName":"Егор Ковалёв","userId":"01841628920051786186"},"user_tz":-300},"id":"t4nyifjQuuO9","outputId":"c9ab13bf-380e-42c0-c0d2-f1020258e025"},"outputs":[{"output_type":"execute_result","data":{"text/plain":["state                  0.075764\n","education              0.028918\n","maritalstatus          0.018927\n","occupation             0.018014\n","usesinternetservice    0.015245\n","homeowner              0.006547\n","customersuspended      0.006157\n","gender                 0.005490\n","usesvoiceservice       0.002775\n","dtype: float64"],"text/html":["<div>\n","<style scoped>\n","    .dataframe tbody tr th:only-of-type {\n","        vertical-align: middle;\n","    }\n","\n","    .dataframe tbody tr th {\n","        vertical-align: top;\n","    }\n","\n","    .dataframe thead th {\n","        text-align: right;\n","    }\n","</style>\n","<table border=\"1\" class=\"dataframe\">\n","  <thead>\n","    <tr style=\"text-align: right;\">\n","      <th></th>\n","      <th>0</th>\n","    </tr>\n","  </thead>\n","  <tbody>\n","    <tr>\n","      <th>state</th>\n","      <td>0.075764</td>\n","    </tr>\n","    <tr>\n","      <th>education</th>\n","      <td>0.028918</td>\n","    </tr>\n","    <tr>\n","      <th>maritalstatus</th>\n","      <td>0.018927</td>\n","    </tr>\n","    <tr>\n","      <th>occupation</th>\n","      <td>0.018014</td>\n","    </tr>\n","    <tr>\n","      <th>usesinternetservice</th>\n","      <td>0.015245</td>\n","    </tr>\n","    <tr>\n","      <th>homeowner</th>\n","      <td>0.006547</td>\n","    </tr>\n","    <tr>\n","      <th>customersuspended</th>\n","      <td>0.006157</td>\n","    </tr>\n","    <tr>\n","      <th>gender</th>\n","      <td>0.005490</td>\n","    </tr>\n","    <tr>\n","      <th>usesvoiceservice</th>\n","      <td>0.002775</td>\n","    </tr>\n","  </tbody>\n","</table>\n","</div><br><label><b>dtype:</b> float64</label>"]},"metadata":{},"execution_count":14}],"source":["cat_target_corr = {}\n","\n","for col in cat_cols:\n","    cat_target_corr[col] = cramers_v(df[col], df[\"churn\"])\n","\n","cat_target_corr = (\n","    pd.Series(cat_target_corr)\n","    .sort_values(ascending=False)\n",")\n","\n","cat_target_corr\n"]},{"cell_type":"markdown","metadata":{"id":"zk-fJEJz6sYz"},"source":["Проанализируем матрицы корреляций. Из них становится очевидно, что сильных линейных связей между фичами и целевой переменной нет. Но тем не менее, мы можем отбросить:\n"," - callingnum - номер телефона, уникальный идентификатор без предсказательной силы\n"," - customerid - уникальный идентификатор пользователя, предсказательной силы также не имеет\n"," - year - год сбора информации, никакой предсказательной силы в нем нет, удалим его\n"," - noadditionallines - фича, содержащая в себе только \"\\N\", удаляем\n","\n","  Отдельно отмечу, что ранее упомянутая фича state имеет самую значительную корреляцию с целевой переменной среди всех категориальных переменных, соответственно, удалять её нецелесообразно\n","  \n","  Удалим перечисленные фичи"]},{"cell_type":"code","execution_count":15,"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"executionInfo":{"elapsed":18,"status":"ok","timestamp":1769953491906,"user":{"displayName":"Егор Ковалёв","userId":"01841628920051786186"},"user_tz":-300},"id":"-bGFajUUDo9P","outputId":"42c3d4d1-2c48-4df3-950d-a770e43616f9"},"outputs":[{"output_type":"execute_result","data":{"text/plain":["(20468, 25)"]},"metadata":{},"execution_count":15}],"source":["df = df.drop(columns=['callingnum', 'customerid','year'])\n","df.shape"]},{"cell_type":"markdown","metadata":{"id":"juwipfccEKe6"},"source":["Далее произведем подготовку данных, разобьем на трейн и тест\n"]},{"cell_type":"code","execution_count":16,"metadata":{"id":"P5RAOeF8wP-l","executionInfo":{"status":"ok","timestamp":1769953491952,"user_tz":-300,"elapsed":41,"user":{"displayName":"Егор Ковалёв","userId":"01841628920051786186"}}},"outputs":[],"source":["# Подготовка данных\n","\n","X = df.drop(columns=[\"churn\"])\n","y = df[\"churn\"].astype(int)\n","\n","categorical_features_for_pipeline = X.select_dtypes(include=['object']).columns\n","numerical_features_for_pipeline = X.select_dtypes(include=[np.number]).columns\n","\n","\n","X_train, X_test, y_train, y_test = train_test_split(\n","    X, y,\n","    test_size=0.2,\n","    stratify=y,\n","    random_state=42\n",")"]},{"cell_type":"markdown","metadata":{"id":"Ik9Nqg9EIS0Y"},"source":["Используем следующие модели: dummy для построения baseline, решающее дерево, рандом форест и градиентный бустинг"]},{"cell_type":"code","execution_count":17,"metadata":{"id":"ObpK1JCoTRFc","colab":{"base_uri":"https://localhost:8080/"},"executionInfo":{"status":"ok","timestamp":1769953509709,"user_tz":-300,"elapsed":17750,"user":{"displayName":"Егор Ковалёв","userId":"01841628920051786186"}},"outputId":"2d97f1e1-ae56-4208-f8ac-b137cdf69dbd"},"outputs":[{"output_type":"stream","name":"stdout","text":["dummy 0.5\n","decision_tree 0.7214872764031117\n","random_forest 0.9790350110560091\n","gradient_boosting 0.7925224056204442\n"]}],"source":["preprocessor_ohe = ColumnTransformer(\n","    transformers=[\n","        ('num', 'passthrough', numerical_features_for_pipeline),\n","        ('cat', OneHotEncoder(handle_unknown='ignore', sparse_output=False),\n","         categorical_features_for_pipeline)\n","    ]\n",")\n","\n","X_train_ohe = preprocessor_ohe.fit_transform(X_train)\n","X_test_ohe = preprocessor_ohe.transform(X_test)\n","\n","models = {\n","    \"dummy\": DummyClassifier(strategy=\"most_frequent\"),\n","    \"decision_tree\": DecisionTreeClassifier(max_depth=6, random_state=42),\n","    \"random_forest\": RandomForestClassifier(n_estimators=200, random_state=42),\n","    \"gradient_boosting\": GradientBoostingClassifier(random_state=42)\n","}\n","\n","for name, model in models.items():\n","    model.fit(X_train_ohe, y_train)\n","    probs = model.predict_proba(X_test_ohe)[:, 1]\n","    print(name, roc_auc_score(y_test, probs))"]},{"cell_type":"code","execution_count":18,"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"executionInfo":{"elapsed":17209,"status":"ok","timestamp":1769953526918,"user":{"displayName":"Егор Ковалёв","userId":"01841628920051786186"},"user_tz":-300},"id":"g0Sh8WVyTRHZ","outputId":"e8883cf3-172d-482d-a9b0-c662e7133232"},"outputs":[{"output_type":"stream","name":"stdout","text":["============================================================\n","DUMMY\n","============================================================\n","Accuracy:  0.9089\n","Precision: 0.0000\n","Recall:    0.0000\n","F1-score:  0.0000\n","ROC-AUC:   0.5000\n","\n","Confusion matrix:\n"," [[3721    0]\n"," [ 373    0]]\n","\n","Classification report:\n","               precision    recall  f1-score   support\n","\n","           0       0.91      1.00      0.95      3721\n","           1       0.00      0.00      0.00       373\n","\n","    accuracy                           0.91      4094\n","   macro avg       0.45      0.50      0.48      4094\n","weighted avg       0.83      0.91      0.87      4094\n","\n","============================================================\n","DECISION_TREE\n","============================================================\n","Accuracy:  0.9079\n","Precision: 0.3571\n","Recall:    0.0134\n","F1-score:  0.0258\n","ROC-AUC:   0.7215\n","\n","Confusion matrix:\n"," [[3712    9]\n"," [ 368    5]]\n","\n","Classification report:\n","               precision    recall  f1-score   support\n","\n","           0       0.91      1.00      0.95      3721\n","           1       0.36      0.01      0.03       373\n","\n","    accuracy                           0.91      4094\n","   macro avg       0.63      0.51      0.49      4094\n","weighted avg       0.86      0.91      0.87      4094\n","\n","============================================================\n","RANDOM_FOREST\n","============================================================\n","Accuracy:  0.9519\n","Precision: 1.0000\n","Recall:    0.4718\n","F1-score:  0.6412\n","ROC-AUC:   0.9790\n","\n","Confusion matrix:\n"," [[3721    0]\n"," [ 197  176]]\n","\n","Classification report:\n","               precision    recall  f1-score   support\n","\n","           0       0.95      1.00      0.97      3721\n","           1       1.00      0.47      0.64       373\n","\n","    accuracy                           0.95      4094\n","   macro avg       0.97      0.74      0.81      4094\n","weighted avg       0.95      0.95      0.94      4094\n","\n","============================================================\n","GRADIENT_BOOSTING\n","============================================================\n","Accuracy:  0.9089\n","Precision: 0.0000\n","Recall:    0.0000\n","F1-score:  0.0000\n","ROC-AUC:   0.7925\n","\n","Confusion matrix:\n"," [[3721    0]\n"," [ 373    0]]\n","\n","Classification report:\n","               precision    recall  f1-score   support\n","\n","           0       0.91      1.00      0.95      3721\n","           1       0.00      0.00      0.00       373\n","\n","    accuracy                           0.91      4094\n","   macro avg       0.45      0.50      0.48      4094\n","weighted avg       0.83      0.91      0.87      4094\n","\n"]}],"source":["#  Обучение и оценка моделей\n","\n","roc_auc_scores = {}\n","roc_curves = {}\n","pr_auc_scores = {}\n","\n","for name, model in models.items():\n","    # обучение\n","    model.fit(X_train_ohe, y_train)\n","\n","    # предсказания\n","    preds = model.predict(X_test_ohe)\n","    probs = model.predict_proba(X_test_ohe)[:, 1]\n","\n","    # метрики\n","    roc_auc = roc_auc_score(y_test, probs)\n","    roc_auc_scores[name] = roc_auc\n","\n","    fpr, tpr, _ = roc_curve(y_test, probs)\n","    roc_curves[name] = (fpr, tpr)\n","\n","    pr_auc_scores[name] = average_precision_score(y_test, probs)\n","\n","    print(\"=\" * 60)\n","    print(name.upper())\n","    print(\"=\" * 60)\n","    print(f\"Accuracy:  {accuracy_score(y_test, preds):.4f}\")\n","    print(f\"Precision: {precision_score(y_test, preds, zero_division=0):.4f}\")\n","    print(f\"Recall:    {recall_score(y_test, preds, zero_division=0):.4f}\")\n","    print(f\"F1-score:  {f1_score(y_test, preds, zero_division=0):.4f}\")\n","    print(f\"ROC-AUC:   {roc_auc:.4f}\")\n","    print(\"\\nConfusion matrix:\\n\", confusion_matrix(y_test, preds))\n","    print(\"\\nClassification report:\\n\", classification_report(y_test, preds, zero_division=0))"]},{"cell_type":"markdown","source":["Так же попробуем обучить CatBoost и проанализировать его работу в сравнении с моделями, для которых проводилась предподготовка категориальных столбцов"],"metadata":{"id":"Iif9EOYCUm__"}},{"cell_type":"code","source":["X_train_cb = X_train.copy()\n","X_test_cb = X_test.copy()\n","\n","cat_features_idx = [\n","    X_train_cb.columns.get_loc(col)\n","    for col in categorical_features_for_pipeline\n","]"],"metadata":{"id":"T6v8c1m7UoRu","executionInfo":{"status":"ok","timestamp":1769953526934,"user_tz":-300,"elapsed":15,"user":{"displayName":"Егор Ковалёв","userId":"01841628920051786186"}}},"execution_count":19,"outputs":[]},{"cell_type":"code","source":["catboost_model = CatBoostClassifier(\n","    iterations=300,\n","    learning_rate=0.05,\n","    depth=6,\n","    random_state=42,\n","    verbose=False\n",")\n","\n","catboost_model.fit(\n","    X_train_cb,\n","    y_train,\n","    cat_features=cat_features_idx\n",")\n","\n","preds_cb = catboost_model.predict(X_test_cb)\n","probs_cb = catboost_model.predict_proba(X_test_cb)[:, 1]\n","print(\"\\n  CatBoost \\n\")\n","\n","print(f\"Accuracy:  {accuracy_score(y_test, preds_cb):.4f}\")\n","print(f\"Precision: {precision_score(y_test, preds_cb, zero_division=0):.4f}\")\n","print(f\"Recall:    {recall_score(y_test, preds_cb, zero_division=0):.4f}\")\n","print(f\"F1-score:  {f1_score(y_test, preds_cb, zero_division=0):.4f}\")\n","print(f\"ROC-AUC:   {roc_auc_score(y_test, probs_cb):.4f}\")\n","print(\"\\nConfusion matrix:\\n\", confusion_matrix(y_test, preds_cb))\n","print(\"\\nClassification report:\\n\", classification_report(y_test, preds, zero_division=0))"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"9Zd1QPE2Usgi","executionInfo":{"status":"ok","timestamp":1769953536213,"user_tz":-300,"elapsed":9277,"user":{"displayName":"Егор Ковалёв","userId":"01841628920051786186"}},"outputId":"d31949d0-f348-4a4d-e1c2-836e2fc17f37"},"execution_count":20,"outputs":[{"output_type":"stream","name":"stdout","text":["\n","  CatBoost \n","\n","Accuracy:  0.9113\n","Precision: 1.0000\n","Recall:    0.0268\n","F1-score:  0.0522\n","ROC-AUC:   0.8900\n","\n","Confusion matrix:\n"," [[3721    0]\n"," [ 363   10]]\n","\n","Classification report:\n","               precision    recall  f1-score   support\n","\n","           0       0.91      1.00      0.95      3721\n","           1       0.00      0.00      0.00       373\n","\n","    accuracy                           0.91      4094\n","   macro avg       0.45      0.50      0.48      4094\n","weighted avg       0.83      0.91      0.87      4094\n","\n"]}]},{"cell_type":"markdown","metadata":{"id":"IijKICIkSWeo"},"source":["Модели обучены. По отчетам уже можем сделать вывод о том, что лучше всего в этом наборе моделей отработал рандом форест, показав самый лучший f1 и recall. Неидеально, но лучше, чем остальные модели. Построим ROC-AUC кривые для обученных моделей."]},{"cell_type":"code","execution_count":25,"metadata":{"colab":{"base_uri":"https://localhost:8080/","height":564},"executionInfo":{"elapsed":928,"status":"ok","timestamp":1769953886068,"user":{"displayName":"Егор Ковалёв","userId":"01841628920051786186"},"user_tz":-300},"id":"77FvxP1XTRJs","outputId":"1a1a4528-3240-4865-e1cb-59f0270216c6"},"outputs":[{"output_type":"display_data","data":{"text/plain":["<Figure size 800x600 with 1 Axes>"],"image/png":"\n"},"metadata":{}}],"source":["\n","# ROC-AUC кривые\n","\n","plt.figure(figsize=(8, 6))\n","\n","# sklearn модели\n","for name, (fpr, tpr) in roc_curves.items():\n","    plt.plot(\n","        fpr,\n","        tpr,\n","        label=f\"{name} (AUC = {roc_auc_scores[name]:.3f})\"\n","    )\n","\n","# catboost\n","probs_cb = catboost_model.predict_proba(X_test_cb)[:, 1]\n","fpr_cb, tpr_cb, _ = roc_curve(y_test, probs_cb)\n","roc_auc_cb = roc_auc_score(y_test, probs_cb)\n","plt.plot(\n","    fpr_cb,\n","    tpr_cb,\n","    label=f\"catboost (AUC = {roc_auc_cb:.3f})\"\n",")\n","\n","plt.plot([0, 1], [0, 1], linestyle=\"--\")\n","plt.xlabel(\"False Positive Rate\")\n","plt.ylabel(\"True Positive Rate\")\n","plt.title(\"ROC-AUC кривые для всех моделей\")\n","plt.legend(loc=\"lower right\")\n","plt.grid(True)\n","plt.show()\n","\n"]},{"cell_type":"markdown","metadata":{"id":"Z-E5yJtbUiOB"},"source":["Графики ROC-AUC уже наглядно показывают нам, что лучше всего в этом наборе моделей отработал именно рандом форест."]},{"cell_type":"code","execution_count":23,"metadata":{"colab":{"base_uri":"https://localhost:8080/","height":564},"collapsed":true,"executionInfo":{"elapsed":42632,"status":"ok","timestamp":1769953794487,"user":{"displayName":"Егор Ковалёв","userId":"01841628920051786186"},"user_tz":-300},"id":"z3yK9KSVTRLs","outputId":"76a1b435-0003-41fd-e1e9-0d5d961737ba"},"outputs":[{"output_type":"display_data","data":{"text/plain":["<Figure size 800x600 with 1 Axes>"],"image/png":"\n"},"metadata":{}}],"source":["# PR для CatBoost (native categoricals)\n","probs_cb = catboost_model.predict_proba(X_test_cb)[:, 1]\n","precision_cb, recall_cb, _ = precision_recall_curve(y_test, probs_cb)\n","ap_cb = average_precision_score(y_test, probs_cb)\n","\n","plt.figure(figsize=(8, 6))\n","\n","# sklearn модели\n","for name, model in models.items():\n","    model.fit(X_train_ohe, y_train)\n","    probs = model.predict_proba(X_test_ohe)[:, 1]\n","\n","    precision, recall, _ = precision_recall_curve(y_test, probs)\n","    ap = average_precision_score(y_test, probs)\n","\n","    plt.plot(recall, precision, label=f\"{name} (AP = {ap:.3f})\")\n","\n","# catboost отдельно\n","plt.plot(recall_cb, precision_cb, label=f\"catboost (AP = {ap_cb:.3f})\")\n","\n","plt.xlabel(\"Recall\")\n","plt.ylabel(\"Precision\")\n","plt.title(\"Precision–Recall curves\")\n","plt.legend()\n","plt.grid(True)\n","plt.show()\n","\n"]},{"cell_type":"markdown","metadata":{"id":"UMW4zsnZV3IY"},"source":["На графике precision-recall так же видно, что лучшее соотношение показывает именно рандом форест, тогда как остальные модели практически не определяют отток."]},{"cell_type":"markdown","metadata":{"id":"AvqyCojHWOCS"},"source":["Какой вывод можно сделать из проделанного исследования: из обученных моделей мы получили то, что без работы с гиперпараметрами и балансировкой классов лучше всего с предсказанием оттока справляется рандом форест. В дальнейшем при внедрении этой модели в бизнес-процессы можно увеличить процент предсказываемого оттока. Так же хочу отметить, что можно дополнительно поработать с бустингом, например, использовать LightGBM или XGBoost, их результаты явно можно приблизить к результатам рандом фореста"]}],"metadata":{"colab":{"provenance":[{"file_id":"1Fx-LwJl7DQK8kev7EwLP7aqLs0Ee87HE","timestamp":1769522374652},{"file_id":"1kOgEnVET9Jk3uHWnqkaIDJ2pSRLtM0uD","timestamp":1764673599746}],"authorship_tag":"ABX9TyMPDg19fwrnC0tRi1zKsBI8"},"kernelspec":{"display_name":"Python 3","name":"python3"},"language_info":{"name":"python"},"widgets":{"application/vnd.jupyter.widget-state+json":{"f80999671b254f668151896f709702cf":{"model_module":"@jupyter-widgets/controls","model_name":"HBoxModel","model_module_version":"1.5.0","state":{"_dom_classes":[],"_model_module":"@jupyter-widgets/controls","_model_module_version":"1.5.0","_model_name":"HBoxModel","_view_count":null,"_view_module":"@jupyter-widgets/controls","_view_module_version":"1.5.0","_view_name":"HBoxView","box_style":"","children":["IPY_MODEL_f9abd8cc1304451580eee1d75a08a316","IPY_MODEL_a53977a000024d94b6a63a44fd669438","IPY_MODEL_c619475b7a8440a5bfe6c0f58f3d1d85"],"layout":"IPY_MODEL_693e9e0d484c4c46a30b18484fc0a47a"}},"f9abd8cc1304451580eee1d75a08a316":{"model_module":"@jupyter-widgets/controls","model_name":"HTMLModel","model_module_version":"1.5.0","state":{"_dom_classes":[],"_model_module":"@jupyter-widgets/controls","_model_module_version":"1.5.0","_model_name":"HTMLModel","_view_count":null,"_view_module":"@jupyter-widgets/controls","_view_module_version":"1.5.0","_view_name":"HTMLView","description":"","description_tooltip":null,"layout":"IPY_MODEL_e8f30e05e262419da76c34a6fad7458b","placeholder":"​","style":"IPY_MODEL_7486f17e7274413bbd55fccec03bc48a","value":"Summarize dataset: 100%"}},"a53977a000024d94b6a63a44fd669438":{"model_module":"@jupyter-widgets/controls","model_name":"FloatProgressModel","model_module_version":"1.5.0","state":{"_dom_classes":[],"_model_module":"@jupyter-widgets/controls","_model_module_version":"1.5.0","_model_name":"FloatProgressModel","_view_count":null,"_view_module":"@jupyter-widgets/controls","_view_module_version":"1.5.0","_view_name":"ProgressView","bar_style":"success","description":"","description_tooltip":null,"layout":"IPY_MODEL_897812c7dc4b49d6a5a6eb479d3f1d02","max":5,"min":0,"orientation":"horizontal","style":"IPY_MODEL_e306cfe379ae4b7eada2834d51705f9f","value":5}},"c619475b7a8440a5bfe6c0f58f3d1d85":{"model_module":"@jupyter-widgets/controls","model_name":"HTMLModel","model_module_version":"1.5.0","state":{"_dom_classes":[],